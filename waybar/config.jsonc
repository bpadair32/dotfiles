{
  "modules-left": [
    "custom/apps",
    "hyprland/workspaces",
    "custom/updates",
    "custom/tasks"
  ],
  "modules-center": [
    "hyprland/window",
    "custom/media"
  ],
  "modules-right": [
    "group/tray",
    "custom/weather",
    "custom/claude",
    "group/hardware",
    "battery",
    "pulseaudio",
    "clock",
    "idle_inhibitor",
    "network",
    "custom/power",
    "custom/notification"
  ],
  "hyprland/workspaces": {
    "format": "{id}{windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "в—Ҹ",
    "window-rewrite": {
      "class<kitty>": " п’ү",
      "class<Alacritty>": " п’ү",
      "class<foot>": " п’ү",
      "class<.*zen.*>": " пӮ¬",
      "class<zen>": " пӮ¬",
      "class<zen-browser>": " пӮ¬",
      "class<app.zen_browser.zen>": " пӮ¬",
      "class<firefox>": " пӮ¬",
      "class<chromium>": " пӮ¬",
      "class<google-chrome>": " пӮ¬",
      "class<brave-browser>": " пӮ¬",
      "class<code>": " п„Ў",
      "class<Code>": " п„Ў",
      "class<neovide>": " п’ү",
      "class<obsidian>": " пүү",
      "class<slack>": " пҶҳ",
      "class<Slack>": " пҶҳ",
      "class<discord>": " пҺ’",
      "class<WebCord>": " пҺ’",
      "class<spotify>": " пҶј",
      "class<Spotify>": " пҶј",
      "class<steam>": " пҶ¶",
      "class<org.gnome.Nautilus>": " пҒ»",
      "class<thunar>": " пҒ»",
      "class<vlc>": " пҖҪ",
      "class<mpv>": " пҖҪ",
      "class<.*gimp.*>": " пҮј",
      "class<blender>": " пҶІ",
      "class<libreoffice.*>": " п…ң",
      "class<thunderbird>": " пғ ",
      "class<1Password>": " пҖЈ",
      "class<org.telegram.desktop>": " пӢҶ",
      "class<signal>": " пҒө",
      "class<.*>": " пӢҗ"
    },
    "on-click": "activate",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "cursor": "pointer",
    "all-outputs": false,
    "show-special": false,
    "persistent-workspaces": {
      "*": 3
    }
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "пғҙ",
      "deactivated": "о°•"
    }
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 40,
    "placeholder": "",
    "rewrite": {
      "(.*) вҖ” Zen Browser": "рҹҢҺ $1",
      "\\*?WebCord - (.*)": "пҺ’  $1",
      "(.*) - Obsidian.*": "пүү $1"
    },
    "separate-outputs": true
  },
  "group/tray": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "tray-modules"
    },
    "modules": [
      "custom/separator",
      "tray"
    ]
  },
  "custom/separator": {
    "format": "|",
    "tooltip": false
  },
  "clock": {
    // "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    // "format-alt": "{:%Y-%m-%d}"
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon}пҠ” {volume}% {format_source}",
    "format-bluetooth-muted": "{icon}пҠ” 0% {format_source}",
    "format-muted": "{icon} 0%",
    "format-source": "п„° {volume}%",
    "format-source-muted": "п„ұ",
    "format-icons": {
      "headphone": "пҖҘ",
      "hands-free": "пҖҘ",
      "headset": "пҖҘ",
      "phone": "пӮ•",
      "portable": "пӮ•",
      "car": "пҶ№",
      "default": [
        "пҖҰ",
        "пҖ§",
        "пҖЁ"
      ]
    },
    "on-click": "pavucontrol"
  },
  "custom/power": {
    "format": "пҖ‘ ",
    "on-click": "~/repos/scripts/power.sh"
  },
  "battery": {
    "interval": 120,
    "states": {
      "warning": 20,
      "critical": 10
    },
    "format": "{icon}  {capacity}%",
    "format-icons": [
      "пү„",
      "пүғ",
      "пүӮ",
      "пүҒ",
      "пүҖ"
    ],
    "max-length": 25
  },
  "cpu": {
    "format": "пӢӣ  {usage}%",
    "interval": 10,
    "max-length": 10
  },
  "memory": {
    "format": "п”ё {percentage}%",
    "interval": 30,
    "max-length": 10
  },
  "disk": {
    "format": "пӮ   {percentage_free}%",
    "interval": 30
  },
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "hardware-modules"
    },
    "modules": [
      "cpu",
      "memory",
      "disk"
    ]
  },
  "network": {
    "interface": "wlp0s20f3",
    "format": "пҮ« ",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)"
  },
  "custom/apps": {
    "format": "пҢӢ",
    "on-click": "sleep 0.2; pkill rofi; rofi -show drun"
  },
  "custom/updates": {
    "format": "{}",
    "return-type": "json",
    "interval": 7200,
    "exec": "~/repos/dotfiles/scripts/updates",
    "on-click": "kitty --class floating -e bash -c 'echo \"=== DNF Updates ===\"; dnf check-update; echo; echo \"=== Flatpak Updates ===\"; flatpak remote-ls --updates; read -p \"Press Enter to close...\"'",
    "tooltip": true
  },
  "custom/tasks": {
    "format": "{}",
    "return-type": "json",
    "interval": 600,
    "exec": "~/repos/dotfiles/scripts/tasks",
    "tooltip": true
  },
  "custom/media": {
    "format": "{icon}{text}",
    "return-type": "json",
    "format-icons": {
      "Playing": "пҒӢ ",
      "Paused": "пҒҢ "
    },
    "max-length": 50,
    "exec": "~/repos/dotfiles/scripts/media-status",
    "on-click": "playerctl play-pause"
  },
  "custom/weather": {
    "format": "{}",
    "return-type": "json",
    "interval": 600,
    "exec": "~/repos/dotfiles/scripts/weather",
    "on-click": "xdg-open 'https://wttr.in'",
    "tooltip": true
  },
  "custom/claude": {
    "format": "{}",
    "return-type": "json",
    "interval": 300,
    "exec": "~/repos/dotfiles/scripts/claude-usage",
    "on-click": "kitty --class floating -e bash -c 'cat ~/.claude/stats-cache.json | jq . | less'",
    "tooltip": true
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "пӮў<span foreground='red'><sup>п‘„</sup></span>",
      "none": "пӮў",
      "dnd-notification": "пҮ·<span foreground='red'><sup>п‘„</sup></span>",
      "dnd-none": "пҮ·",
      "inhibited-notification": "пӮў<span foreground='red'><sup>п‘„</sup></span>",
      "inhibited-none": "пӮў",
      "dnd-inhibited-notification": "пҮ·<span foreground='red'><sup>п‘„</sup></span>",
      "dnd-inhibited-none": "пҮ·"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "reload_style_on_change": true
}
